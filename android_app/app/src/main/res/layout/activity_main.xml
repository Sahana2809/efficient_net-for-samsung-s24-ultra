<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    tools:context=".MainActivity">

    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66121212" />

    <!-- Controlled Evaluation Setup -->
    <androidx.cardview.widget.CardView
        android:id="@+id/referenceCard"
        android:layout_width="160dp"
        android:layout_height="200dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#2C2C2C"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            
            <ImageView
                android:id="@+id/referenceImage"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scaleType="centerCrop" />
            
            <TextView
                android:id="@+id/groundTruthText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="GT: Goldfish"
                android:textColor="#03DAC5"
                android:textSize="12sp"
                android:gravity="center"
                android:background="#33000000"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#CC000000"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detecting..."
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/top5PredictionsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#BBBBBB"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/comparisonText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Accuracy: --"
            android:textColor="#FFEB3B"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="4dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/metricsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Inference: 0ms | FPS: 0"
            android:textColor="#03DAC5"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Next Image"
                android:layout_marginEnd="4dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btnBenchmark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Benchmark All"
                android:layout_marginStart="4dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:backgroundTint="#03DAC5"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MODEL:"
                android:textColor="#03DAC5"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"/>

            <ToggleButton
                android:id="@+id/modelSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textOn="QNN BIN"
                android:textOff="ONNX"
                android:checked="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2C2C2C"/>
        </LinearLayout>

        <RadioGroup
            android:id="@+id/backendGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <RadioButton
                android:id="@+id/btnCpu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CPU"
                android:textColor="#FFFFFF"
                android:checked="true"
                android:buttonTint="#03DAC5"/>

            <RadioButton
                android:id="@+id/btnGpu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NNAPI (accelerator)"
                android:textColor="#FFFFFF"
                android:buttonTint="#03DAC5"/>

            <RadioButton
                android:id="@+id/btnNpu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NPU"
                android:textColor="#FFFFFF"
                android:buttonTint="#03DAC5"/>
        </RadioGroup>

        <TextView
            android:id="@+id/disclosureText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="EfficientNet-V2-S (8.8B ops). Benchmarked on Tiny ImageNet subset."
            android:textColor="#888888"
            android:textSize="10sp"
            android:gravity="center"
            android:textStyle="italic"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
